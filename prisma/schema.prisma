generator client {
  provider = "prisma-client-js"
  output   = "../lib/prisma-client"
}

datasource db {
  provider  = "postgresql"
}

model User {
  id                String             @id @default(cuid())
  name              String?
  email             String             @unique
  emailVerified     DateTime?
  image             String?
  password_hash     String?
  createdAt         DateTime           @default(now())
  accounts          Account[]
  sessions          Session[]
  connectedAccounts ConnectedAccount[]
  posts             Post[]
  projects          Project[]
  projectImages     ProjectImage[]
  aiUsageOption     String             @default("Normal AI Use")
  patternCaches     PatternCache[]
  automationSettings AutomationSettings?
  automationEvents   AutomationEvent[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ConnectedAccount {
  id                  String   @id @default(uuid())
  userId              String
  facebookUserId      String
  pageId              String
  pageAccessToken     String
  instagramBusinessId String
  longLivedUserToken  String
  tokenExpiry         DateTime
  createdAt           DateTime @default(now())
  profilePictureUrl   String?
  username            String?
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts               Post[]
  automationSettings AutomationSettings?
  automationEvents   AutomationEvent[]

  @@unique([userId, pageId])
}

model Post {
  id                 String           @id @default(cuid())
  userId             String
  connectedAccountId String
  projectId          String?
  caption            String?
  imageUrl           String
  createdAt          DateTime         @default(now())
  instagramMediaId   String?
  reach              Int              @default(0)
  saves              Int              @default(0)
  views              Int              @default(0)
  likes              Int              @default(0)
  comments           Int              @default(0)
  mediaType          MediaType        @default(IMAGE)
  connectedAccount   ConnectedAccount @relation(fields: [connectedAccountId], references: [id], onDelete: Cascade)
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  project            Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  schedules          Schedule[]
}

model Project {
  id              String         @id @default(cuid())
  userId          String
  name            String
  description     String?
  
  // Basic Info
  objective       String?        // awareness / engagement / sales / leads
  defaultHashtags String[]
  
  // Target Audience
  ageRange        String?
  gender          String?
  location        String?
  profession      String?
  
  // Brand Voice & Tone
  toneStyle       String?        // casual / professional / witty / bold / inspirational
  writingStyleNotes String?
  exampleCaptions String?        // 2-3 samples
  
  // Posting Plan
  postingFrequency String?
  preferredTimeSlots String?
  campaignDuration String?
  
  // CTA
  preferredCtaTypes String?      // DM / link in bio / comment / share
  
  // Constraints / Avoidances
  wordsToAvoid    String?
  toneRestrictions String?
  
  // Extra Instructions
  customPromptNotes String?
  campaignSpecificInstructions String?

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts           Post[]
  images          ProjectImage[]
  patternCaches   PatternCache[]
}

model ProjectImage {
  id          String   @id @default(cuid())
  projectId   String
  userId      String
  url         String
  storagePath String
  fileName    String
  createdAt   DateTime @default(now())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Schedule {
  id           String         @id @default(cuid())
  postId       String
  scheduledFor DateTime
  status       ScheduleStatus @default(PENDING)
  createdAt    DateTime       @default(now())
  post         Post           @relation(fields: [postId], references: [id], onDelete: Cascade)
}

enum ScheduleStatus {
  PENDING
  PROCESSING
  PUBLISHED
  FAILED
}

model PatternCache {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  data      String   // JSON-serialized PatternAnalysis
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

enum MediaType {
  IMAGE
  VIDEO
}

model AutomationSettings {
  id               String           @id @default(cuid())
  userId           String           @unique
  accountId        String           @unique
  autoDmReply      Boolean          @default(false)
  dmDelayMin       Int              @default(1)
  dmDelayMax       Int              @default(5)
  dmMode           String           @default("TEMPLATE") // "TEMPLATE" or "AI"
  dmTemplate       String?
  dmAiPersonality  String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  connectedAccount ConnectedAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model AutomationEvent {
  id               String   @id @default(cuid())
  userId           String
  accountId        String
  igUserId         String
  eventType        String
  payload          String
  status           String   @default("PENDING")
  error            String?
  scheduledFor     DateTime
  processedAt      DateTime?
  createdAt        DateTime @default(now())

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  connectedAccount ConnectedAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
}
